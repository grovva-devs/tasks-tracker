{
  "name": "@onboarding-tracker/shared",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && node -e \"require('fs').readdirSync('dist',{recursive:true}).filter(f=>f.endsWith('.js')&&require('fs').readFileSync('dist/'+f,'utf8').includes('from \\\"./')).forEach(f=>{let c=require('fs').readFileSync('dist/'+f,'utf8');c=c.replace(/from \\\"\\.\\/([^\\\"]+)\\\"/g,(m,p)=>{if(p.endsWith('.js'))return m;return 'from \\\"./'+p+'.js\\\"'});require('fs').writeFileSync('dist/'+f,c)})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}